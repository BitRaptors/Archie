# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
EXPO_PUBLIC_FIREBASE_APP_ID="your-app-id"
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# Backend API URL
# Development: http://localhost:8000/api
# Production: https://api.yourdomain.com/api
EXPO_PUBLIC_API_BASE_URL="http://localhost:8000/api"

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Google OAuth Client IDs (get from Firebase Console > Authentication > Sign-in method > Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="your-ios-client-id.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="your-android-client-id.apps.googleusercontent.com"

# Environment Switching Guide:
# 1. For local development: Use http://localhost:8000/api
# 2. For staging: Use https://staging-api.yourdomain.com/api
# 3. For production: Use https://api.yourdomain.com/api
#
# You can create separate .env files for different environments:
# - .env.development (local dev)
# - .env.staging (staging server)
# - .env.production (production server)
#
# Then use: EXPO_PUBLIC_ENV=production npx expo start
