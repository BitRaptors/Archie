  "data_fetching": {
    "framework": "Retrofit + Okhttp + Moshi + Kotlin Coroutines + Flow",
    "configuration": "app/src/main/java/com/bitraptors/babyweather/common/domain/api/",
    
    "data_fetching_mechanisms": [
      {
        "name": "Retrofit Network Calls",
        "location": "common/domain/api/networkModule.kt",
        "mechanism": "Retrofit with OkHttp client, Moshi serialization, interceptors for auth/logging",
        "async_pattern": "suspend fun with Coroutine scope, wrapped in try-catch or Flow.catch()",
        "examples": [
          "LocationRepository.fetchAllLocations() -> suspend fun with Retrofit call",
          "SettingsRepository.fetchUserSettings() -> suspend fun",
          "SubscriptionRepository.checkSubscriptionStatus() -> calls RevenueCat SDK"
        ],
        "error_handling": "Catches exceptions, maps to domain error types, emits to error event stream"
      },
      {
        "name": "StateFlow Observation Pattern",
        "location": "repositories/*.kt",
        "mechanism": "Repositories expose StateFlow<T> for UI observation. Data flows: Repository -> ViewModel -> Fragment UI",
        "examples": [
          "LocationRepository.primaryLocationFlow: StateFlow<Location> (observed by DashboardViewModel)",
          "SettingsRepository.temperatureUnitFlow: StateFlow<TemperatureUnit> (observed across app)",
          "AppStartService.startStateFlow: StateFlow<StartState> (observed by LoadingFragment)"
        ],
        "lazy_initialization": "init() functions called in BabyWeatherApplication.onCreate() or on first subscription"
      },
      {
        "name": "Coroutine-based Async",
        "location": "viewModels/*.kt, repositories/*.kt",
        "mechanism": "CoroutineScope(Dispatchers.IO) for background work, Dispatchers.Main for UI updates",
        "examples": [
          "BabyWeatherApplication.onStateChanged() -> CoroutineScope(Dispatchers.IO).launch { locationManager.startTrack() }",
          "ViewModel.loadData() -> viewModelScope.launch { repository.fetchData() }"
        ],
        "lifecycle_awareness": "ViewModel.viewModelScope automatically cancelled when fragment destroyed"
      },
      {
        "name": "RevenueCat SDK Integration",
        "location": "common/domain/repository/subscription/SubscriptionRepository.kt",
        "mechanism": "RevenueCat Purchases SDK for in-app purchases and subscription management",
        "async_pattern": "Callback-based (OnError, OnRevenueCatInfo) and async SDK methods",
        "examples": [
          "Purchases.sharedInstance.purchasePackage() -> initiates purchase, returns result/error",
          "Purchases.sharedInstance.restorePurchases() -> restores previous purchases"
        ],
        "error_mapping": "Maps PurchasesErrorCode to domain errors, emits ShowPurchaseErrorDialog events"
      },
      {
        "name": "SharedPreferences/Local Persistence",
        "location": "SettingsRepository, various data stores