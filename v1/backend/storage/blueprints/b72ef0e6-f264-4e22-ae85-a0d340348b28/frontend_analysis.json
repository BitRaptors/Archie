      {
        "pattern": "Global event navigation",
        "implementation": "MainViewModel observes NavigationRequest sealed class from viewModels, delegates to NavController",
        "example": "SubscriptionDetailViewModel emits NavigationRequest.To(NavDirections) on purchase success -> MainViewModel navigates"
      },
      {
        "pattern": "Modal dialogs",
        "implementation": "BottomSheetDialogFragment or AlertDialog",
        "example": "LoginBottomSheetFragment shows over current screen without navigation stack entry"
      }
