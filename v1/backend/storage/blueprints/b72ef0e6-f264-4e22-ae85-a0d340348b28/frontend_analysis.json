        "behavior": "Displays product offerings from RevenueCat, handles purchase flow, emits error events on failures"
      },
      {
        "name": "MainViewModel",
        "scope": "Activity-scoped (retained across Fragment transactions)",
        "state_flow": "navigationEventFlow: StateFlow<NavigationRequest>, loadingFlow: StateFlow<Boolean>",
        "state_shape": "{ currentRoute, isPurchaseLoading, globalErrorMessage }",
        "behavior": "Coordinates navigation between fragments, manages global loading state, handles cross-screen events (purchase errors, theme changes, navigation requests)"
      }
    ],

    "form_state_handling": [
      {
        "form": "BabySettingsFragment",
        "inputs": ["babyName: TextInputEditText", "birthDate: DatePicker", "avatarEmoji: GridView", "paletteColor: RadioGroup"],
        "validation": "Triggered on value change and form submit. Validates non-empty name, valid birth date (not future), emoji/color selection.",
        "submission": "POST to backend with baby profile data. Updates SettingsRepository on success. Shows success toast.",
        "error_display": "Form-level error messages, inline field errors, snackbar notifications"
      },
      {
        "form": "FeedbackFragment",
        "inputs": ["category: Spinner", "message: EditText"],
        "validation": "Non-empty message, valid category selection",
        "submission": "POST to backend feedback endpoint. Shows success dialog.",
        "error_display": "Dialog with error message and retry option"
      },
      {
        "form": "LoginBottomSheetFragment",
        "inputs": ["email: EditText"],
        "validation": "Valid email format",
        "submission": "POST magic link or initiate Google OAuth. Backend sends verification email or redirects to Google auth.",
        "error_display": "Inline error message, dialog on auth failure"
      }
    ],

    "event_patterns": [
      {
        "name": "Navigation Events",
        "mechanism": "NavigationRequest sealed class emitted by ViewModels to MainViewModel",
        "examples": [
          "NavigationRequest.To(NavDirections)",
          "NavigateBackToDashboardRequest",
          "NavigationEventOutput (bottom nav item selection)"
        ],
        "subscribers": ["MainActivity observes navigationEventFlow from MainViewModel"]
      },
      {
        "name": "Error Events",
        "mechanism": "BaseController (event controller) collects errors from repositories and emits to MainActivity",
        "examples": [
          "ShowPurchaseErrorDialog (for subscription errors)",
          "NetworkError, AuthError, ValidationError"
        ],
        "subscribers": ["MainActivity.subscribeToErrors()"]
      },
      {
        "name": "Analytics Events",
        "mechanism": "Sealed class AnalyticsEvent emitted to RaptorAnalytics.track()",
        "examples": [
          "AnalyticsEvent.AppForeground(), AppBackground(), AppTerminates()",
          "AnalyticsEvent.PurchaseInitiated(sku), PurchaseCompleted(sku)"
        ],
        "subscribers": ["RaptorAnalytics event sink (Firebase, Mixpanel, etc.)"]
      }
    ],

    "rationale": "MVVM + StateFlow chosen for clear separation of concerns (UI/business logic), reactive data binding with Kotlin Flow, and built-in lifecycle awareness. Repository pattern abstracts data sources. Koin enables dependency injection and modular architecture. AppStartService acts as global state orchestrator for initialization and app-wide events. Fragment-scoped ViewModels reduce boilerplate; Activity-scoped MainViewModel coordinates cross-fragment navigation and global events."
  },

