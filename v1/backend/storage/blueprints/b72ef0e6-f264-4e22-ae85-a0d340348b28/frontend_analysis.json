  "state_management": {
    "approach": "MVVM with ViewModel + StateFlow/LiveData + Koin DI",
    "pattern_description": "Each Fragment has an associated ViewModel holding UI state as StateFlow<UiModel<T>>. Repository layer manages domain logic. Services (AppStartService, LocationRepository, SettingsRepository, etc.) maintain shared application state.",
    
    "global_state": [
      {
        "name": "AppStartService",
        "location": "app/src/main/java/com/bitraptors/babyweather/common/domain/repository/appstart/AppStartService.kt",
        "purpose": "Application initialization state and readiness. Determines initial navigation destination (dashboard vs settings vs login). Manages app lifecycle events.",
        "state_flow": "startStateFlow: StateFlow<StartState>",
        "key_methods": ["init()", "refreshAfterLogin()", "trackAppStart()", "waitForAppReady()", "refreshDashboard()"],
        "subscribers": ["LoadingFragment", "MainActivity", "BabyWeatherApplication"]
      },
      {
        "name": "LocationRepository",
        "location": "app/src/main/java/com/bitraptors/babyweather/common/domain/repository/home/LocationRepository.kt",
        "purpose": "Manages saved user locations, fetches weather for each location, caches results. Provides location data to dashboard and locations screens.",
        "state_flow": "primary and secondary location flows",
        "key_methods": ["fetchAllLocations()", "addLocation()", "deleteLocation()", "searchLocations()"],
        "subscribers": ["LocationsFragment", "DashboardFragment", "MainActivity"]
      },
      {
        "name": "SettingsRepository",
        "location": "app/src/main/java/com/bitraptors/babyweather/common/domain/repository/settings/SettingsRepository.kt",
        "purpose": "User preferences (temperature unit, temperature type, theme, language, app icon, notifications). Persists to SharedPreferences or backend.",
        "state_flow": "temperatureUnitFlow, temperatureTypeFlow, themeFlow, languageFlow, appIconFlow",
        "key_methods": ["updateSetting()", "getSetting()", "subscribeToSettingsChanges()"],
        "subscribers": ["SettingsFragment", "SettingsDetailFragment", "DashboardFragment", "MainActivity"]
      },
      {
        "name": "SubscriptionRepository",
        "location": "app/src/main/java/com/bitraptors/babyweather/common/domain/repository/subscription/SubscriptionRepository.kt",
        "purpose": "Manages Pro subscription status, product catalog from RevenueCat, purchase state, and expiration tracking.",
        "state_flow": "isProFlow: StateFlow<Boolean>, purchaseStatusFlow",
        "key_methods": ["purchaseProduct()", "restorePurchases()", "checkSubscriptionStatus()"],
        "subscribers": ["MainActivity", "DashboardFragment", "SettingsFragment", "SubscriptionDetailFragment"]
      },
      {
        "name": "RaptorAnalytics",
        "location": "util/services/analytics/",
        "purpose": "Global event tracking for user actions, app lifecycle events, feature usage. Aggregates to Firebase Analytics, Mixpanel, or custom backend.",
        "key_events": ["AnalyticsEvent.AppForeground()", "AnalyticsEvent.AppBackground()", "AnalyticsEvent.AppTerminates()", "AnalyticsEvent.PurchaseInitiated()", etc.],
        "subscribers": ["BabyWeatherApplication", "all ViewModels"]
      },
      {
        "name": "DarkModeHelper",
        "location": "hu.bitraptors.presentation.darkmode (external library)",
        "purpose": "Manages dark mode theme application and preference syncing. Observes theme setting changes and applies to entire application.",
        "state_flow": "themeFlow: StateFlow<DarkMode>",
        "key_methods": ["setApplicationDefaultTheme()", "applyTheme()"],
        "subscribers": ["MainActivity", "BabyWeatherApplication"]
      },
      {
        "name": "LocationManager",
        "location": "app/src/main/java/com/bitraptors/babyweather/sdk/location/LocationManager.kt",
        "purpose": "Device location tracking (GPS/network-based). Provides current user location for primary location auto-selection and location-based features.",
        "key_methods": ["startTrack()", "stopTrack()"],
        "subscribers": ["BabyWeatherApplication", "LocationRepository"]
      }
    ],

