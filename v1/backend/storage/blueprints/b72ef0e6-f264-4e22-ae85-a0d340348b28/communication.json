  "pattern_guidelines": [
    {
      "scenario": "Displaying weather data for a location",
      "pattern": "MVVM + Repository + Flow<T>",
      "flow": [
        "Fragment (page_dashboard) observes DashboardViewModel.weatherState: StateFlow<WeatherUiState>",
        "ViewModel calls repository.fetchWeatherData(locationKey, childId)",
        "Repository calls APIService.fetchLocation() via Retrofit",
        "APIService returns NetworkResponse<HomePageDto, String>",
        "Repository maps success to domain model and emits via StateFlow",
        "Fragment renders weather UI with animations (slide_in_left.xml, etc.)",
        "On error: checkError() emits to errorFlow; Fragment shows snackbar"
      ],
      "rationale": "Separates UI logic from business logic; reactive updates; centralized error handling"
    },
    {
      "scenario": "User adds a new baby profile",
      "pattern": "ViewModel event emission + Navigation callback",
      "flow": [
        "page_baby_settings Fragment collects input",
        "Fragment calls viewModel.addBaby(babyName, birthDate, color)",
        "ViewModel calls repository.addBaby(childDto)",
        "Repository calls APIService.addBaby() with Bearer token",
        "On success: ViewModel emits RefreshFragmentRequest event or navigation event",
        "MainActivity's NavController pops back to settings or refreshes list",
        "On error: checkError() captures error; Fragment shows validation error dialog"
      ],
      "rationale": "One-way data flow; events trigger side effects; auth token injected automatically"
    },
    {
      "scenario": "Fetching contextual weather tips",
      "pattern": "Public API endpoint + aggressive caching",
      "flow": [
        "page_tips Fragment calls viewModel.fetchTips(language)",
        "ViewModel calls repository.fetchTips() (no auth required)",
        "Repository checks local cache; if stale, calls APIService.fetchTips(language)",
        "Tips cached locally (likely in Room database, not shown)",
        "Fragment renders tips in RecyclerView with cell_tip.xml items",
        "User can filter by tags (cell_tips_filter.xml); filtered locally from cache"
      ],
      "rationale": "Public data doesn't require auth; caching reduces network calls; tag filtering is deterministic"
    },
    {
      "scenario": "Handling network timeout",
      "pattern": "NetworkErrorResponse.NetworkError → User-facing message",
      "flow": [
        "OkHttp request times out after 30 seconds",
        "Retrofit wraps in IOException",
        "NetworkResponseAdapterFactory catches and maps to NetworkResponse.Failure<NetworkErrorResponse.NetworkError>",
        "checkError() extension catches and calls errorMessage()",
        "errorMessage() returns ErrorResult.Network.message (localized string)",
        "ViewModel emits to errorFlow; Fragment shows snackbar with retry button"
      ],
      "rationale": "Explicit error types allow tailored user feedback; timeout configurable globally"
    },
    {
      "scenario": "Authentication failure (expired token)",
      "pattern": "HttpRequestInterceptor redirect + OAuth refresh",
      "flow": [
        "API call returns 401 Unauthorized",
        "NetworkResponseAdapterFactory maps to NetworkResponse.Failure<AuthenticationError>",
        "checkError() returns ErrorResult.Authentication.message",
        "MainActivity/ViewModel detects auth error",
        "Triggers page_login_bottomsheet dialog (dialog_login.xml)",
        "User re-authenticates; new token stored in loginManager",
        "HttpRequestInterceptor injects new token in retry request"
      ],
      "rationale": "Centralized token injection; automatic re-auth flow; stateless API design"
    },
    {
      "scenario": "Swipe-to-delete location",
      "pattern": "Custom gesture detection (SwipeLayout) + confirmation dialog",
      "flow": [
        "page_locations Fragment uses SwipeLayout parent in cell_location.xml",
        "User swipes left on location item",
        "SwipeLayout.OnSwipeListener.onSwipeLeft() callback triggered",
        "Fragment shows alert dialog (view_alert_double_option.xml) for confirmation",
        "User confirms deletion",
        "Fragment calls viewModel.deleteLocation(locationId)",
        "ViewModel calls repository.deleteBaby() with Bearer token",
        "On success: ViewModel updates locationList StateFlow; RecyclerView auto-refreshes",
        "Animate removal with dissapear.xml"
      ],
      "rationale": "Low-level gesture handling decoupled from business logic; confirmation prevents accidental deletion"
    },
    {
      "scenario": "Image cropping for baby avatar",
