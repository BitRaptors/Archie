# Backend Environment Variables
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local

# ── Application ──────────────────────────────────────────────
APP_NAME=Archie API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database Backend ──────────────────────────────────────────
# "postgres" (recommended, local Docker) or "supabase" (cloud)
DB_BACKEND=postgres

# ── PostgreSQL (recommended — start with: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/archie

# ── Supabase (alternative — required when DB_BACKEND=supabase)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-key

# ── Redis (optional — without it, analysis runs in-process) ──
REDIS_URL=redis://localhost:6379

# ── AI (REQUIRED) ───────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Fast model for intermediate analysis phases (observation, discovery, layers, etc.)
DEFAULT_AI_MODEL=claude-haiku-4-5-20251001
# Model for final blueprint synthesis (can use a more capable model like claude-sonnet-4-5-20250929)
# claude-haiku-4-5: max 64K output | claude-sonnet-4-5: max 16K output
SYNTHESIS_AI_MODEL=claude-haiku-4-5-20251001
# Max output tokens for blueprint synthesis phases
SYNTHESIS_MAX_TOKENS=64000

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Storage ──────────────────────────────────────────────────
STORAGE_PATH=./storage
TEMP_STORAGE_PATH=./temp

# ── Analysis ─────────────────────────────────────────────────
ANALYSIS_TIMEOUT_SECONDS=3600

# ── Intent Layer ─────────────────────────────────────────────
# INTENT_LAYER_ENABLE_AI_ENRICHMENT=true
# INTENT_LAYER_MAX_CONCURRENT=5
# INTENT_LAYER_MIN_FILES=2
# INTENT_LAYER_GENERATE_CODEBASE_MAP=true

# ── GitHub API (optional — users can also provide their own) ─
# GITHUB_TOKEN=ghp_...
