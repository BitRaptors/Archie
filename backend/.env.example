# Backend Environment Variables
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local

# ── Application ──────────────────────────────────────────────
APP_NAME=Repository Analysis API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Supabase (REQUIRED) ─────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI (REQUIRED) ───────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
# Fast model for intermediate analysis phases (observation, discovery, layers, etc.)
DEFAULT_AI_MODEL=claude-haiku-4-5-20251001
# Model for final blueprint synthesis (can use a more capable model like claude-sonnet-4-5-20250929)
# claude-haiku-4-5: max 64K output | claude-sonnet-4-5: max 16K output
SYNTHESIS_AI_MODEL=claude-haiku-4-5-20251001
# Max output tokens for blueprint synthesis phases
SYNTHESIS_MAX_TOKENS=10000

# ── Embedding ────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Database ──────────────────────────────────────────
VECTOR_DB_TYPE=pgvector
# QDRANT_URL=
# QDRANT_API_KEY=
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ── Storage ──────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_PATH=./storage
TEMP_STORAGE_PATH=./temp
# GCS_BUCKET_NAME=
# S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ── GitHub (optional — users can also provide their own) ────
# GITHUB_TOKEN=ghp_...

# ── Analysis ─────────────────────────────────────────────────
MAX_ANALYSIS_WORKERS=4
ANALYSIS_TIMEOUT_SECONDS=3600

# ── GitHub API (optional) ────────────────────────────────────
GITHUB_TOKEN=