#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Single entry point for development.
#
#   ./dev              — set up (if needed) + start everything
#   ./dev --reset      — force full re-setup then start
#
# First run: installs prereqs, creates venv, installs deps, seeds DB, starts.
# Subsequent runs: detects changes (new deps, stale prompts, missing migrations)
# and fixes them automatically before starting.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

info()  { echo -e "${GREEN}  ✓${NC} $*"; }
warn()  { echo -e "${YELLOW}  ⚠${NC} $*"; }
err()   { echo -e "${RED}  ✗${NC} $*"; }
step()  { echo -e "\n${BOLD}${BLUE}▸ $*${NC}"; }

# ── Flags ─────────────────────────────────────────────────────────────────────
FORCE_RESET=false
for arg in "$@"; do
    case "$arg" in
        --reset) FORCE_RESET=true ;;
    esac
done

# ── Helpers ───────────────────────────────────────────────────────────────────

run_with_timeout() {
    local secs="$1"; shift
    "$@" &
    local pid=$!
    local elapsed=0
    while kill -0 "$pid" 2>/dev/null; do
        sleep 1
        elapsed=$((elapsed + 1))
        if [ "$elapsed" -ge "$secs" ]; then
            kill "$pid" 2>/dev/null; wait "$pid" 2>/dev/null || true
            return 124
        fi
    done
    wait "$pid"
}

docker_daemon_ok() { run_with_timeout 10 docker info >/dev/null 2>&1; }

resolve_docker_compose() {
    if run_with_timeout 10 docker compose version &>/dev/null; then
        echo "docker compose"
    elif command -v docker-compose &>/dev/null; then
        echo "docker-compose"
    fi
}

env_get() {
    grep -E "^${2}=" "$1" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '[:space:]"'"'" || true
}

file_hash() {
    if command -v md5sum &>/dev/null; then
        md5sum "$1" 2>/dev/null | cut -d' ' -f1
    else
        md5 -q "$1" 2>/dev/null
    fi
}

# ── Platform detection ────────────────────────────────────────────────────────
OS="$(uname -s)"
case "$OS" in
    MINGW*|MSYS*|CYGWIN*)
        err "Run this inside WSL2, not Git Bash/MSYS."
        echo "    wsl --install && wsl"
        exit 1 ;;
esac

IS_WSL=false
if [ "$OS" = "Linux" ] && grep -qi 'microsoft\|wsl' /proc/version 2>/dev/null; then
    IS_WSL=true
fi

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 1: Prerequisites
# ══════════════════════════════════════════════════════════════════════════════

step "Checking prerequisites"

ensure_brew() {
    if [ "$OS" = "Darwin" ] && ! command -v brew &>/dev/null; then
        info "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [ -f /opt/homebrew/bin/brew ]; then eval "$(/opt/homebrew/bin/brew shellenv)"; fi
        if [ -f /usr/local/bin/brew ]; then eval "$(/usr/local/bin/brew shellenv)"; fi
    fi
}

# Python
if ! command -v python3 &>/dev/null; then
    if [ "$OS" = "Darwin" ]; then
        ensure_brew; brew install python@3.13
    elif [ "$OS" = "Linux" ]; then
        sudo apt-get update -qq && sudo apt-get install -y -qq python3 python3-venv python3-pip
    else
        err "Please install Python 3.11+: https://www.python.org/downloads/"; exit 1
    fi
fi
if ! python3 -c "import sys; exit(0 if sys.version_info >= (3, 11) else 1)"; then
    err "Python 3.11+ required (found $(python3 --version))"; exit 1
fi
info "Python $(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"

# Node
if ! command -v node &>/dev/null; then
    if [ "$OS" = "Darwin" ]; then
        ensure_brew; brew install node
    elif [ "$OS" = "Linux" ]; then
        curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
        sudo apt-get install -y -qq nodejs
    else
        err "Please install Node.js 18+: https://nodejs.org/"; exit 1
    fi
fi
NODE_MAJOR=$(node -v | sed 's/v//' | cut -d. -f1)
if [ "$NODE_MAJOR" -lt 18 ]; then
    err "Node 18+ required (found $(node -v))"; exit 1
fi
info "Node $(node -v)"

# Docker
if ! command -v docker &>/dev/null; then
    if [ "$OS" = "Darwin" ]; then
        ensure_brew; brew install docker
    elif [ "$OS" = "Linux" ]; then
        curl -fsSL https://get.docker.com | sh
        sudo usermod -aG docker "$USER"
    else
        err "Please install Docker: https://docs.docker.com/get-docker/"; exit 1
    fi
fi

# Ensure Docker daemon is running
if ! docker_daemon_ok; then
    if [ "$OS" = "Darwin" ]; then
        if command -v colima &>/dev/null; then
            warn "Starting Colima..."
            colima start --memory 4 --cpu 2 2>&1 || true
        elif [ -d "/Applications/Docker.app" ]; then
            warn "Starting Docker Desktop..."
            open -a Docker
        else
            warn "Installing Colima (lightweight Docker runtime)..."
            ensure_brew; brew install colima
            colima start --memory 4 --cpu 2 2>&1 || true
        fi
        for i in $(seq 1 30); do
            docker_daemon_ok && break
            [ "$i" -eq 30 ] && { err "Docker daemon didn't start. Try manually."; exit 1; }
            sleep 2
        done
    elif [ "$OS" = "Linux" ]; then
        if [ "$IS_WSL" = true ]; then
            if command -v systemctl &>/dev/null && systemctl is-system-running &>/dev/null 2>&1; then
                sudo systemctl start docker
            else
                sudo service docker start
            fi
        else
            sudo systemctl start docker
        fi
        sleep 2
        docker_daemon_ok || { err "Docker daemon failed to start"; exit 1; }
    fi
fi
info "Docker $(docker --version | cut -d' ' -f3 | tr -d ',')"

# Docker Compose
DOCKER_COMPOSE=$(resolve_docker_compose)
if [ -z "$DOCKER_COMPOSE" ]; then
    if [ "$OS" = "Darwin" ]; then
        ensure_brew; brew install docker-compose
        COMPOSE_BIN="$(brew --prefix docker-compose 2>/dev/null)/bin/docker-compose"
        if [ -x "$COMPOSE_BIN" ]; then
            mkdir -p ~/.docker/cli-plugins
            ln -sfn "$COMPOSE_BIN" ~/.docker/cli-plugins/docker-compose
        fi
        DOCKER_COMPOSE=$(resolve_docker_compose)
    fi
    [ -z "$DOCKER_COMPOSE" ] && { err "Docker Compose not available"; exit 1; }
fi
info "Docker Compose"

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 2: Environment (.env.local files)
# ══════════════════════════════════════════════════════════════════════════════

step "Environment"

BACKEND_ENV="backend/.env.local"
FRONTEND_ENV="frontend/.env.local"

# Backend .env.local — create if missing, default to postgres
if [ ! -f "$BACKEND_ENV" ] || [ "$FORCE_RESET" = true ]; then
    cat > "$BACKEND_ENV" <<'ENVEOF'
# ── Database ─────────────────────────────────────────────────────
DB_BACKEND=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/archie

# ── AI (REQUIRED — get yours at console.anthropic.com) ───────────
ANTHROPIC_API_KEY=

# ── Redis (optional — without it, analysis runs in-process) ─────
REDIS_URL=redis://localhost:6379

# ── GitHub (optional — users can also provide per-request) ───────
# GITHUB_TOKEN=
ENVEOF
    info "Created $BACKEND_ENV (postgres defaults)"
else
    info "$BACKEND_ENV exists"
fi

# Frontend .env.local
if [ ! -f "$FRONTEND_ENV" ] || [ "$FORCE_RESET" = true ]; then
    mkdir -p frontend
    echo "NEXT_PUBLIC_API_URL=http://localhost:8000" > "$FRONTEND_ENV"
    info "Created $FRONTEND_ENV"
else
    info "$FRONTEND_ENV exists"
fi

# Check for the one thing we actually need from the user
ANTHROPIC_KEY=$(env_get "$BACKEND_ENV" "ANTHROPIC_API_KEY")
if [ -z "$ANTHROPIC_KEY" ]; then
    echo ""
    echo -e "  ${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${YELLOW}  ANTHROPIC_API_KEY is not set in $BACKEND_ENV${NC}"
    echo -e "  ${YELLOW}  Get one at: ${BOLD}https://console.anthropic.com${NC}"
    echo -e "  ${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    if [ -t 0 ]; then
        read -rp "  Paste your ANTHROPIC_API_KEY (or press Enter to skip for now): " USER_KEY
        if [ -n "$USER_KEY" ]; then
            if [ "$(uname -s)" = "Darwin" ]; then
                sed -i '' "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=${USER_KEY}|" "$BACKEND_ENV"
            else
                sed -i "s|^ANTHROPIC_API_KEY=.*|ANTHROPIC_API_KEY=${USER_KEY}|" "$BACKEND_ENV"
            fi
            info "API key saved"
        else
            warn "Skipped — the app will start but analysis won't work until you set it"
        fi
    else
        warn "Non-interactive — set ANTHROPIC_API_KEY in $BACKEND_ENV before using analysis"
    fi
fi

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 3: Docker services (PostgreSQL + Redis)
# ══════════════════════════════════════════════════════════════════════════════

DB_BACKEND=$(env_get "$BACKEND_ENV" "DB_BACKEND")
DB_BACKEND=${DB_BACKEND:-postgres}

if [ "$DB_BACKEND" = "postgres" ]; then
    step "Docker services (PostgreSQL + Redis)"

    # Check for port conflicts before starting containers
    for _port_check in 5432 6379; do
        _port_pid=$(lsof -ti :"$_port_check" 2>/dev/null | head -1 || true)
        if [ -n "$_port_pid" ]; then
            _port_name=$(lsof -i :"$_port_check" -sTCP:LISTEN 2>/dev/null | tail -1 | awk '{print $1}' || echo "unknown")
            # If it's already our Docker container, that's fine
            if ! docker compose ps --format '{{.Ports}}' 2>/dev/null | grep -q "$_port_check"; then
                warn "Port $_port_check is in use by $_port_name (PID $_port_pid)"
                if [ "$_port_check" = 6379 ]; then
                    warn "Tip: stop it with 'brew services stop redis' or 'kill $_port_pid'"
                    warn "Continuing without Docker Redis — will use existing instance"
                else
                    err "Port 5432 (PostgreSQL) is required. Stop the conflicting process and retry."
                    exit 1
                fi
            fi
        fi
    done

    COMPOSE_OUTPUT=$($DOCKER_COMPOSE up -d 2>&1) || {
        echo "$COMPOSE_OUTPUT"
        if echo "$COMPOSE_OUTPUT" | grep -qiE "port is already allocated"; then
            # Redis port conflict — start only PostgreSQL
            if echo "$COMPOSE_OUTPUT" | grep -q "6379" && ! echo "$COMPOSE_OUTPUT" | grep -q "5432"; then
                warn "Redis port 6379 already in use — starting PostgreSQL only"
                $DOCKER_COMPOSE up -d postgres || { err "PostgreSQL container failed to start"; exit 1; }
            else
                err "Port conflict — check 'docker ps' and 'lsof -i :5432 -i :6379'"
                exit 1
            fi
        elif echo "$COMPOSE_OUTPUT" | grep -qiE "connection refused|timeout|no such host|network|dial tcp|TLS handshake"; then
            if colima status &>/dev/null 2>&1; then
                warn "Network issue — restarting Colima..."
                colima stop 2>/dev/null || true; sleep 2
                colima start --memory 4 --cpu 2 2>&1 || true
                # Wait for Docker daemon to be fully ready after Colima restart
                for _cw in $(seq 1 30); do
                    docker_daemon_ok && break
                    [ "$_cw" -eq 30 ] && { err "Docker daemon not ready after Colima restart"; exit 1; }
                    sleep 2
                done
                $DOCKER_COMPOSE up -d || { err "Docker Compose still failing"; exit 1; }
            else
                err "Network error pulling Docker images — check your connection"; exit 1
            fi
        else
            err "Docker Compose failed"; exit 1
        fi
    }

    # Wait for PostgreSQL (check host-side port, not just container-internal)
    for i in $(seq 1 30); do
        if (echo > /dev/tcp/localhost/5432) &>/dev/null 2>&1; then
            # Port is reachable — now verify DB is accepting queries
            $DOCKER_COMPOSE exec -T postgres pg_isready -U postgres >/dev/null 2>&1 && break
        fi
        [ "$i" -eq 30 ] && { err "PostgreSQL not reachable on localhost:5432 after 30s"; exit 1; }
        sleep 1
    done
    info "PostgreSQL ready"

    # Verify database exists; if not, create it and apply migration
    DB_EXISTS=$($DOCKER_COMPOSE exec -T postgres psql -U postgres -tAc \
        "SELECT 1 FROM pg_database WHERE datname='archie'" 2>/dev/null || echo "")
    if [ "$DB_EXISTS" != "1" ]; then
        warn "Database 'archie' not found — creating..."
        $DOCKER_COMPOSE exec -T postgres psql -U postgres -c "CREATE DATABASE archie" >/dev/null 2>&1
        info "Database 'archie' created"
    fi

    # Apply migration (idempotent)
    $DOCKER_COMPOSE exec -T postgres psql -U postgres -d archie \
        < backend/migrations/001_initial_setup.sql >/dev/null 2>&1 || true

    # Verify all tables exist; if not, re-apply migration
    EXPECTED_TABLES=11
    TABLES_OK=$($DOCKER_COMPOSE exec -T postgres psql -U postgres -d archie -tAc \
        "SELECT count(*) FROM information_schema.tables WHERE table_schema='public' AND table_name IN ('users','user_profiles','repositories','analyses','analysis_prompts','prompt_revisions','analysis_data','embeddings','analysis_events','discovery_ignored_dirs','library_capabilities')" 2>/dev/null || echo "0")
    if [ "${TABLES_OK:-0}" -lt "$EXPECTED_TABLES" ]; then
        warn "Missing tables (${TABLES_OK}/${EXPECTED_TABLES}) — re-applying migration..."
        $DOCKER_COMPOSE exec -T postgres psql -U postgres -d archie \
            < backend/migrations/001_initial_setup.sql 2>&1 | tail -5
        # Re-check
        TABLES_OK=$($DOCKER_COMPOSE exec -T postgres psql -U postgres -d archie -tAc \
            "SELECT count(*) FROM information_schema.tables WHERE table_schema='public' AND table_name IN ('users','user_profiles','repositories','analyses','analysis_prompts','prompt_revisions','analysis_data','embeddings','analysis_events','discovery_ignored_dirs','library_capabilities')" 2>/dev/null || echo "0")
        if [ "${TABLES_OK:-0}" -lt "$EXPECTED_TABLES" ]; then
            err "Migration failed — only ${TABLES_OK}/${EXPECTED_TABLES} tables found"
            exit 1
        fi
    fi
    info "Database ready (${TABLES_OK}/${EXPECTED_TABLES} tables verified)"
else
    step "Database: Supabase (remote)"
    info "Using remote Supabase — ensure SUPABASE_URL and SUPABASE_KEY are set in $BACKEND_ENV"
fi

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 4: Backend dependencies + prompts
# ══════════════════════════════════════════════════════════════════════════════

step "Backend setup"

cd backend

# Create venv if missing
if [ ! -d ".venv" ] || [ "$FORCE_RESET" = true ]; then
    python3 -m venv .venv
    info "Created Python venv"
fi

# Install/update deps only when requirements.txt changes
REQ_HASH=$(file_hash requirements.txt)
CACHED_HASH=$(cat .venv/.req-hash 2>/dev/null || echo "")

if [ "$REQ_HASH" != "$CACHED_HASH" ] || [ "$FORCE_RESET" = true ]; then
    .venv/bin/pip install --quiet --upgrade pip
    .venv/bin/pip install --quiet -r requirements.txt
    echo "$REQ_HASH" > .venv/.req-hash
    info "Python dependencies installed"
else
    info "Python dependencies up to date"
fi

# Auto-reseed prompts when version changes
PROMPTS_VERSION=$(python3 -c "import json; print(json.load(open('prompts.json'))['version'])" 2>/dev/null || echo "")
SYNCED_VERSION=$(cat .prompts-version 2>/dev/null || echo "")

_seed_prompts() {
    # Retry up to 3 times — DB may still be starting
    for _attempt in 1 2 3; do
        if PYTHONPATH=src .venv/bin/python scripts/seed_prompts.py 2>&1; then
            return 0
        fi
        if [ "$_attempt" -lt 3 ]; then
            warn "Prompt seed attempt $_attempt failed — retrying in 3s..."
            sleep 3
        fi
    done
    return 1
}

_needs_seed() {
    # Check if version changed
    if [ -n "$PROMPTS_VERSION" ] && [ "$PROMPTS_VERSION" != "$SYNCED_VERSION" ]; then
        return 0
    fi
    # Check if no version marker at all
    if [ -z "$SYNCED_VERSION" ]; then
        return 0
    fi
    # Version matches — but verify prompts actually exist in DB
    if [ "$DB_BACKEND" = "postgres" ]; then
        PROMPT_COUNT=$($DOCKER_COMPOSE exec -T postgres psql -U postgres -d archie -tAc \
            "SELECT count(*) FROM analysis_prompts" 2>/dev/null || echo "0")
        if [ "${PROMPT_COUNT:-0}" -lt 1 ]; then
            warn "Version marker says v${SYNCED_VERSION} but DB has 0 prompts — reseeding..."
            rm -f .prompts-version
            return 0
        fi
    fi
    return 1
}

if _needs_seed; then
    warn "Seeding prompts (v${SYNCED_VERSION:-none} → v${PROMPTS_VERSION})..."
    if _seed_prompts; then
        info "Prompts synced (v${PROMPTS_VERSION})"
    else
        err "Prompt seeding failed after 3 attempts — analysis will not work"
        err "Fix DB connectivity and re-run ./run"
        exit 1
    fi
else
    info "Prompts up to date (v${SYNCED_VERSION})"
fi

cd "$ROOT"

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 5: Frontend dependencies
# ══════════════════════════════════════════════════════════════════════════════

step "Frontend setup"

cd frontend

LOCK_HASH=$(file_hash package-lock.json 2>/dev/null || echo "none")
CACHED_LOCK=$(cat node_modules/.lock-hash 2>/dev/null || echo "")

if [ ! -d "node_modules" ] || [ "$LOCK_HASH" != "$CACHED_LOCK" ] || [ "$FORCE_RESET" = true ]; then
    npm install --silent
    echo "$LOCK_HASH" > node_modules/.lock-hash
    info "Frontend dependencies installed"
else
    info "Frontend dependencies up to date"
fi

cd "$ROOT"

# ══════════════════════════════════════════════════════════════════════════════
#  PHASE 6: Start services
# ══════════════════════════════════════════════════════════════════════════════

step "Starting services"

# Cleanup on exit
BACKEND_PID="" FRONTEND_PID="" WORKER_PID=""
cleanup() {
    echo -e "\n${YELLOW}  Shutting down...${NC}"
    [ -n "$WORKER_PID" ]   && kill "$WORKER_PID"   2>/dev/null || true
    [ -n "$FRONTEND_PID" ] && kill "$FRONTEND_PID"  2>/dev/null || true
    [ -n "$BACKEND_PID" ]  && kill "$BACKEND_PID"   2>/dev/null || true
    exit 0
}
trap cleanup SIGINT SIGTERM

# Read backend port
BACKEND_PORT=$(env_get backend/.env.local "PORT")
BACKEND_PORT=${BACKEND_PORT:-8000}

# Start backend
cd backend
source .venv/bin/activate
python src/main.py &
BACKEND_PID=$!
cd "$ROOT"

# Start ARQ worker if Redis is available
REDIS_URL=$(env_get backend/.env.local "REDIS_URL")
REDIS_URL=${REDIS_URL:-redis://localhost:6379}
REDIS_HOST=$(echo "$REDIS_URL" | sed -E 's|^redis://([^:/]+).*|\1|')
REDIS_PORT_NUM=$(echo "$REDIS_URL" | sed -E 's|^redis://[^:]+:([0-9]+).*|\1|')
REDIS_PORT_NUM=${REDIS_PORT_NUM:-6379}

ANALYSIS_MODE="in-process"
if (echo > /dev/tcp/"$REDIS_HOST"/"$REDIS_PORT_NUM") &>/dev/null 2>&1; then
    ANALYSIS_MODE="arq"
fi

if [ "$ANALYSIS_MODE" = "arq" ]; then
    cd backend
    PYTHONPATH="${PYTHONPATH:-}:$(pwd)/src" python -m workers.worker &
    WORKER_PID=$!
    cd "$ROOT"
fi

# Wait for backend to boot
sleep 2
if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    err "Backend failed to start"
    exit 1
fi

# Start frontend
cd frontend
FRONTEND_LOG=$(mktemp)
npm run dev > "$FRONTEND_LOG" 2>&1 &
FRONTEND_PID=$!
cd "$ROOT"

# Wait for frontend to be ready
FRONTEND_PORT=4000
for i in {1..10}; do
    sleep 1
    PORT_LINE=$(grep -oE "localhost:[0-9]+" "$FRONTEND_LOG" 2>/dev/null | head -1 || true)
    if [ -n "$PORT_LINE" ]; then
        FRONTEND_PORT=$(echo "$PORT_LINE" | cut -d: -f2)
        break
    fi
done

if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
    err "Frontend failed to start"
    tail -20 "$FRONTEND_LOG" 2>/dev/null
    rm -f "$FRONTEND_LOG"
    kill "$BACKEND_PID" 2>/dev/null || true
    exit 1
fi
rm -f "$FRONTEND_LOG"

# ══════════════════════════════════════════════════════════════════════════════
#  Ready!
# ══════════════════════════════════════════════════════════════════════════════

echo ""
echo -e "${GREEN}  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}  ${BOLD}Ready!${NC}"
echo -e "${GREEN}  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${BOLD}App:${NC}      http://localhost:${FRONTEND_PORT}"
echo -e "  ${BOLD}API:${NC}      http://localhost:${BACKEND_PORT}"
echo -e "  ${BOLD}API Docs:${NC} http://localhost:${BACKEND_PORT}/docs"
echo -e "  ${BOLD}Database:${NC} ${DB_BACKEND}"
echo -e "  ${BOLD}Analysis:${NC} ${ANALYSIS_MODE}"
echo -e "${GREEN}  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "  ${DIM}Ctrl+C to stop${NC}"
